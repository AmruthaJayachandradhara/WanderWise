# Infra retry / circuit breaker (Phase 3 — defaults are fine for most deployments)
# LLM_RETRY_ATTEMPTS=3
# LLM_RETRY_BASE_DELAY=1.0
# LLM_CIRCUIT_FAILURE_THRESHOLD=5
# LLM_CIRCUIT_COOLDOWN_S=60.0

# Guardrail thresholds
# GUARDRAIL_TOPICALITY_THRESHOLD=0.95
# GUARDRAIL_GROUNDING_THRESHOLD=0.80
# GUARDRAIL_MAX_REFLECTION_ATTEMPTS=2

# Booking & actions (Phase 4 — defaults are fine; JSON map of booking type → provider)
# BOOKING_PROVIDER_MAP={"flight": "duffel", "hotel": "duffel", "restaurant": "mock"}

# Cache TTLs (seconds)
# CACHE_TTL_VISA_DOCS=86400
# CACHE_TTL_WEATHER=3600
# CACHE_TTL_FLIGHTS=0
# CACHE_SEMANTIC_SIMILARITY_THRESHOLD=0.92
